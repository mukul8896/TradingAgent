# =============================================================
# TradingAgent central configuration — SINGLE SOURCE OF TRUTH
# Copy to .env and edit. Defaults are SAFE: paper mode, no live
# trading, delivery sell blocked.
# =============================================================

# ---- Trading mode ----
# paper = simulated trading only (default, safe)
# live  = real broker API (also requires ALLOW_LIVE_TRADING=true)
TRADING_MODE=paper

ENABLE_INTRADAY_TRADING=true
ENABLE_SWING_TRADING=true

# Master switch for real-money orders. Must be true AND TRADING_MODE=live
# for any real order to be possible.
ALLOW_LIVE_TRADING=false
REQUIRE_MANUAL_APPROVAL_FOR_LIVE_ORDERS=true

# ---- Per-action permissions (apply to live mode) ----
ALLOW_INTRADAY_BUY=true
ALLOW_INTRADAY_SELL=true
ALLOW_DELIVERY_BUY=true
# Delivery sell requires manual verification — keep false.
ALLOW_DELIVERY_SELL=false

# ---- Risk management ----
MAX_RISK_PER_TRADE_PERCENT=1
MAX_DAILY_LOSS_PERCENT=2
MAX_OPEN_POSITIONS=5
MAX_POSITION_SIZE_PERCENT=20
MIN_RISK_REWARD_RATIO=1.5

# ---- Paper trading ----
PAPER_STARTING_CAPITAL=1000000

# ---- Broker (Angel One SmartAPI) — only needed for live data/orders ----
BROKER_NAME=angelone
BROKER_API_KEY=
BROKER_CLIENT_CODE=
BROKER_PASSWORD=
BROKER_TOTP_SECRET=

# ---- Optional data/news APIs ----
NEWS_API_KEY=

# ---- Optional notifications ----
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
